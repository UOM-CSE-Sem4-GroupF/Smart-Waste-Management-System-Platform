            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "5.8.9",
                "chart": "emqx",
                "first_deployed": 1776747507,
                "last_deployed": 1776747507,
                "name": "emqx",
                "namespace": "messaging",
                "notes": "",
                "revision": 1,
                "values": "{\"emqxConfig\":{\"EMQX_DASHBOARD__DEFAULT_PASSWORD\":\"swms-emqx-dev-2026\",\"EMQX_DASHBOARD__DEFAULT_USERNAME\":\"admin\",\"EMQX_LOG__CONSOLE__LEVEL\":\"info\",\"EMQX_MQTT__MAX_CONNECTIONS\":\"1000\"},\"image\":{\"pullPolicy\":\"IfNotPresent\",\"repository\":\"emqx/emqx\",\"tag\":\"5.6.0\"},\"persistence\":{\"enabled\":true,\"size\":\"1Gi\",\"storageClass\":\"gp3\"},\"replicaCount\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}},\"service\":{\"annotations\":{\"service.beta.kubernetes.io/aws-load-balancer-scheme\":\"internet-facing\",\"service.beta.kubernetes.io/aws-load-balancer-type\":\"nlb\"},\"dashboard\":18083,\"mqtt\":1883,\"mqttssl\":8883,\"nodePorts\":{\"dashboard\":31083,\"mqtt\":31883},\"type\":\"LoadBalancer\",\"ws\":8083,\"wss\":8084}}",
