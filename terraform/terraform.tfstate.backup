            ],
            "name": "emqx",
            "namespace": "messaging",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://repos.emqx.io/charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [
              {
                "name": "persistence.storageClass",
                "type": "",
                "value": "gp3"
              },
              {
                "name": "service.annotations.service\\.beta\\.kubernetes\\.io/aws-load-balancer-scheme",
                "type": "",
                "value": "internet-facing"
              },
              {
                "name": "service.annotations.service\\.beta\\.kubernetes\\.io/aws-load-balancer-type",
                "type": "",
                "value": "nlb"
              },
              {
                "name": "service.type",
                "type": "",
                "value": "LoadBalancer"
              }
            ],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# Group F — Smart Waste Management System\r\n# EMQX MQTT Broker — Helm Values (Local Dev)\r\n# Chart: emqx/emqx (official EMQX v5 Helm chart)\r\n# Deployed into: messaging namespace\r\n#\r\n# Usage: helm upgrade --install emqx emqx/emqx -n messaging -f messaging/emqx/values-dev.yaml\r\n#\r\n# Provides:\r\n#   - MQTT on NodePort 31883       (ESP32 / Node-RED connects here)\r\n#   - EMQX Dashboard on NodePort 31083\r\n#   - Management REST API on port 18083 (ClusterIP, used by bootstrap Job)\r\n\r\n# ─── Replica Count ────────────────────────────────────────────────\r\nreplicaCount: 1\r\n\r\n# ─── Image ────────────────────────────────────────────────────────\r\nimage:\r\n  repository: emqx/emqx\r\n  tag: \"5.6.0\"\r\n  pullPolicy: IfNotPresent\r\n\r\n# ─── EMQX Configuration ───────────────────────────────────────────\r\nemqxConfig:\r\n  # Dashboard credentials\r\n  EMQX_DASHBOARD__DEFAULT_USERNAME: \"admin\"\r\n  EMQX_DASHBOARD__DEFAULT_PASSWORD: \"swms-emqx-dev-2026\"\r\n\r\n  # Allow higher connection limits for local dev testing\r\n  EMQX_MQTT__MAX_CONNECTIONS: \"1000\"\r\n\r\n  # Log level for cleaner output\r\n  EMQX_LOG__CONSOLE__LEVEL: \"info\"\r\n\r\n# ─── Service Configuration ────────────────────────────────────────\r\n# Use the EMQX chart's native flat port format\r\nservice:\r\n  type: NodePort\r\n\r\n  # Port numbers (the container-side ports)\r\n  mqtt: 1883\r\n  mqttssl: 8883\r\n  ws: 8083\r\n  wss: 8084\r\n  dashboard: 18083\r\n\r\n  # NodePort assignments (the host-side ports)\r\n  nodePorts:\r\n    mqtt: 31883      # F1 ESP32 / Node-RED connects here\r\n    dashboard: 31083 # EMQX Dashboard UI\r\n\r\n# ─── Persistence ──────────────────────────────────────────────────\r\n# Enabled so Kafka bridge rules survive pod restarts (stored in Mnesia DB)\r\npersistence:\r\n  enabled: true\r\n  size: 1Gi\r\n\r\n# ─── Resource Limits ─────────────────────────────────────────────\r\nresources:\r\n  requests:\r\n    cpu: 100m\r\n    memory: 256Mi\r\n  limits:\r\n    cpu: 500m\r\n    memory: 512Mi\r\n"
            ],
            "verify": false,
            "version": "5.8.9",
            "wait": true,
            "wait_for_jobs": false
          },
