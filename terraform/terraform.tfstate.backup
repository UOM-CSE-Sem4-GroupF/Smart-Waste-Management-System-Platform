    {
      "mode": "managed",
      "type": "kubernetes_config_map",
      "name": "keycloak_realm",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "binary_data": {},
            "data": {
              "waste-management-realm.json": "{\r\n  \"id\": \"waste-management\",\r\n  \"realm\": \"waste-management\",\r\n  \"displayName\": \"Group F — Smart Waste Management System\",\r\n  \"enabled\": true,\r\n  \"sslRequired\": \"external\",\r\n  \"registrationAllowed\": false,\r\n  \"loginWithEmailAllowed\": true,\r\n  \"duplicateEmailsAllowed\": false,\r\n  \"resetPasswordAllowed\": true,\r\n  \"editUsernameAllowed\": false,\r\n  \"bruteForceProtected\": true,\r\n  \"accessTokenLifespan\": 300,\r\n  \"refreshTokenMaxReuse\": 0,\r\n  \"roles\": {\r\n    \"realm\": [\r\n      {\r\n        \"name\": \"admin\",\r\n        \"description\": \"Full system access — all management operations\"\r\n      },\r\n      {\r\n        \"name\": \"supervisor\",\r\n        \"description\": \"Monitors dashboards, handles escalations, can cancel jobs\"\r\n      },\r\n      {\r\n        \"name\": \"fleet-operator\",\r\n        \"description\": \"Manages vehicle fleet and driver assignments\"\r\n      },\r\n      {\r\n        \"name\": \"driver\",\r\n        \"description\": \"Field driver — can accept/reject jobs, mark bins collected\"\r\n      },\r\n      {\r\n        \"name\": \"viewer\",\r\n        \"description\": \"Read-only access to dashboards and reports\"\r\n      },\r\n      {\r\n        \"name\": \"sensor-device\",\r\n        \"description\": \"Automated role for EMQX/IoT device authentication\"\r\n      }\r\n    ]\r\n  },\r\n  \"clients\": [\r\n    {\r\n      \"clientId\": \"swms-dashboard\",\r\n      \"name\": \"SWMS Next.js Dashboard\",\r\n      \"description\": \"Next.js supervisor dashboard (F3)\",\r\n      \"enabled\": true,\r\n      \"publicClient\": false,\r\n      \"standardFlowEnabled\": true,\r\n      \"implicitFlowEnabled\": false,\r\n      \"directAccessGrantsEnabled\": false,\r\n      \"clientAuthenticatorType\": \"client-secret\",\r\n      \"secret\": \"dashboard-client-secret-dev\",\r\n      \"redirectUris\": [\r\n        \"http://localhost:3000/*\",\r\n        \"http://swms-dashboard.local/*\"\r\n      ],\r\n      \"webOrigins\": [\r\n        \"http://localhost:3000\",\r\n        \"http://swms-dashboard.local\"\r\n      ],\r\n      \"protocol\": \"openid-connect\",\r\n      \"attributes\": {\r\n        \"access.token.lifespan\": \"300\",\r\n        \"use.refresh.tokens\": \"true\"\r\n      },\r\n      \"defaultClientScopes\": [\r\n        \"openid\",\r\n        \"profile\",\r\n        \"email\",\r\n        \"roles\"\r\n      ],\r\n      \"optionalClientScopes\": []\r\n    },\r\n    {\r\n      \"clientId\": \"swms-mobile\",\r\n      \"name\": \"SWMS Flutter Driver App\",\r\n      \"description\": \"Flutter mobile app for drivers (F3)\",\r\n      \"enabled\": true,\r\n      \"publicClient\": true,\r\n      \"standardFlowEnabled\": true,\r\n      \"implicitFlowEnabled\": false,\r\n      \"directAccessGrantsEnabled\": true,\r\n      \"redirectUris\": [\r\n        \"io.groupf.swms://callback\",\r\n        \"http://localhost/*\"\r\n      ],\r\n      \"webOrigins\": [\r\n        \"*\"\r\n      ],\r\n      \"protocol\": \"openid-connect\",\r\n      \"attributes\": {\r\n        \"pkce.code.challenge.method\": \"S256\",\r\n        \"access.token.lifespan\": \"300\"\r\n      },\r\n      \"defaultClientScopes\": [\r\n        \"openid\",\r\n        \"profile\",\r\n        \"email\",\r\n        \"roles\"\r\n      ],\r\n      \"optionalClientScopes\": []\r\n    },\r\n    {\r\n      \"clientId\": \"kong-gateway\",\r\n      \"name\": \"Kong API Gateway\",\r\n      \"description\": \"Kong uses this to validate JWTs via OIDC introspection\",\r\n      \"enabled\": true,\r\n      \"publicClient\": false,\r\n      \"serviceAccountsEnabled\": true,\r\n      \"standardFlowEnabled\": false,\r\n      \"directAccessGrantsEnabled\": false,\r\n      \"clientAuthenticatorType\": \"client-secret\",\r\n      \"secret\": \"kong-client-secret-dev\",\r\n      \"protocol\": \"openid-connect\"\r\n    }\r\n  ],\r\n  \"identityProviders\": [],\r\n  \"users\": [\r\n    {\r\n      \"username\": \"test-supervisor\",\r\n      \"email\": \"supervisor@swms-dev.local\",\r\n      \"enabled\": true,\r\n      \"emailVerified\": true,\r\n      \"firstName\": \"Test\",\r\n      \"lastName\": \"Supervisor\",\r\n      \"realmRoles\": [\r\n        \"supervisor\"\r\n      ],\r\n      \"credentials\": [\r\n        {\r\n          \"type\": \"password\",\r\n          \"value\": \"swms-supervisor-dev\",\r\n          \"temporary\": false\r\n        }\r\n      ]\r\n    },\r\n    {\r\n      \"username\": \"test-driver\",\r\n      \"email\": \"driver@swms-dev.local\",\r\n      \"enabled\": true,\r\n      \"emailVerified\": true,\r\n      \"firstName\": \"Test\",\r\n      \"lastName\": \"Driver\",\r\n      \"realmRoles\": [\r\n        \"driver\"\r\n      ],\r\n      \"attributes\": {\r\n        \"zone_id\": [\r\n          \"Zone-1\"\r\n        ],\r\n        \"vehicle_id\": [\r\n          \"LORRY-01\"\r\n        ],\r\n        \"shift_start\": [\r\n          \"08:00\"\r\n        ],\r\n        \"shift_end\": [\r\n          \"17:00\"\r\n        ]\r\n      },\r\n      \"credentials\": [\r\n        {\r\n          \"type\": \"password\",\r\n          \"value\": \"swms-driver-dev\",\r\n          \"temporary\": false\r\n        }\r\n      ]\r\n    }\r\n  ]\r\n}"
            },
