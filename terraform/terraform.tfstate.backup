      "name": "kong",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "kong",
            "cleanup_on_fail": false,
            "create_namespace": false,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "kong",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "3.9",
                "chart": "kong",
                "first_deployed": 1776747405,
                "last_deployed": 1776747405,
                "name": "kong",
                "namespace": "gateway",
                "notes": "To connect to Kong, please execute the following commands:\n\nHOST=$(kubectl get svc --namespace gateway kong-kong-proxy -o jsonpath='{.status.loadBalancer.ingress[0].ip}')\nPORT=$(kubectl get svc --namespace gateway kong-kong-proxy -o jsonpath='{.spec.ports[0].port}')\nexport PROXY_IP=${HOST}:${PORT}\ncurl $PROXY_IP\n\nOnce installed, please follow along the getting started guide to start using\nKong: https://docs.konghq.com/kubernetes-ingress-controller/latest/guides/getting-started/\n\n",
                "revision": 1,
                "values": "{\"admin\":{\"enabled\":true,\"http\":{\"containerPort\":8001,\"enabled\":true},\"tls\":{\"enabled\":false},\"type\":\"ClusterIP\"},\"dblessConfig\":{\"configMap\":\"kong-declarative-config\"},\"deployment\":{\"kong\":{\"enabled\":true}},\"env\":{\"database\":\"off\"},\"ingressController\":{\"enabled\":true,\"env\":{\"kong_admin_tls_skip_verify\":\"true\"},\"installCRDs\":false},\"livenessProbe\":{\"httpGet\":{\"path\":\"/status\",\"port\":8001},\"initialDelaySeconds\":30,\"periodSeconds\":10},\"proxy\":{\"annotations\":{\"service.beta.kubernetes.io/aws-load-balancer-scheme\":\"internet-facing\",\"service.beta.kubernetes.io/aws-load-balancer-type\":\"nlb\"},\"http\":{\"enabled\":true,\"nodePort\":\"\"},\"tls\":{\"enabled\":false},\"type\":\"LoadBalancer\"},\"readinessProbe\":{\"httpGet\":{\"path\":\"/status\",\"port\":8001},\"initialDelaySeconds\":15,\"periodSeconds\":10},\"replicaCount\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}}}",
                "version": "3.2.0"
              }
            ],
            "name": "kong",
            "namespace": "gateway",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://charts.konghq.com",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [
              {
                "name": "proxy.annotations.service\\.beta\\.kubernetes\\.io/aws-load-balancer-scheme",
                "type": "",
                "value": "internet-facing"
              },
              {
                "name": "proxy.annotations.service\\.beta\\.kubernetes\\.io/aws-load-balancer-type",
                "type": "",
                "value": "nlb"
              },
              {
                "name": "proxy.http.nodePort",
                "type": "",
                "value": ""
              },
              {
                "name": "proxy.type",
                "type": "",
                "value": "LoadBalancer"
              }
            ],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# Kong API Gateway — Helm Values (Local Dev)\r\n# Chart: kong/kong\r\n# Deployed into: gateway namespace\r\n# Mode: DB-less (declarative config via ConfigMap)\r\n\r\n# DB-less mode natively supported by the chart\r\nenv:\r\n  database: \"off\"\r\n\r\n# Tell the chart to automatically mount and configure the ConfigMap\r\ndblessConfig:\r\n  configMap: kong-declarative-config\r\n\r\ndeployment:\r\n  kong:\r\n    enabled: true\r\n\r\n# Enable the Ingress Controller to watch K8s Ingress resources\r\ningressController:\r\n  enabled: true\r\n  installCRDs: false\r\n  env:\r\n    kong_admin_tls_skip_verify: \"true\"\r\n\r\n# Single replica for local dev\r\nreplicaCount: 1\r\n\r\n# Expose Kong proxy via NodePort so Minikube can reach it\r\nproxy:\r\n  type: NodePort\r\n  http:\r\n    enabled: true\r\n    nodePort: 30080\r\n  tls:\r\n    enabled: false\r\n\r\n# Kong Admin API — cluster-internal only (no external exposure)\r\nadmin:\r\n  enabled: true\r\n  type: ClusterIP\r\n  http:\r\n    enabled: true\r\n    containerPort: 8001\r\n  tls:\r\n    enabled: false\r\n\r\n# Resource limits suited for Minikube\r\nresources:\r\n  requests:\r\n    cpu: 100m\r\n    memory: 256Mi\r\n  limits:\r\n    cpu: 500m\r\n    memory: 512Mi\r\n\r\n# Readiness/liveness probes point to the admin API\r\nreadinessProbe:\r\n  httpGet:\r\n    path: /status\r\n    port: 8001\r\n  initialDelaySeconds: 15\r\n  periodSeconds: 10\r\n\r\nlivenessProbe:\r\n  httpGet:\r\n    path: /status\r\n    port: 8001\r\n  initialDelaySeconds: 30\r\n  periodSeconds: 10\r\n"
            ],
            "verify": false,
            "version": "3.2.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "aws_eks_cluster.main",
            "aws_eks_node_group.main",
            "aws_iam_role.eks_cluster",
            "aws_iam_role.eks_nodes",
            "aws_iam_role_policy_attachment.ebs_csi",
