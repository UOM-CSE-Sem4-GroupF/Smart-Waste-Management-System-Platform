    {
      "mode": "managed",
      "type": "kubernetes_config_map",
      "name": "kong_declarative_config",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "binary_data": {},
            "data": {
              "kong.yaml": "_format_version: \"3.0\"\n_transform: true\n\n# =========================================================\n# UPSTREAM SERVICES\n# These are the DNS names of services inside the cluster.\n# Format: \u003cservice-name\u003e.\u003cnamespace\u003e.svc.cluster.local\n# Services must be deployed before Kong can route to them.\n# =========================================================\n\nservices:\n  # ---------------------------------------------------------\n  # F3 — Bin Status Service\n  # Serves all bin state and zone summary queries\n  # ---------------------------------------------------------\n  - name: bin-status-service\n    url: http://bin-status-service.waste-dev.svc.cluster.local:3001\n    connect_timeout: 3000\n    read_timeout: 10000\n    write_timeout: 10000\n    routes:\n      - name: bins-api\n        paths:\n          - /api/v1/bins\n        strip_path: false\n        methods:\n          - GET\n          - POST\n          - PUT\n          - PATCH\n        plugins:\n          - name: jwt\n            config:\n              claims_to_verify:\n                - exp\n          - name: rate-limiting\n            config:\n              minute: 100\n              policy: local\n\n      - name: zones-api\n        paths:\n          - /api/v1/zones\n        strip_path: false\n        methods:\n          - GET\n        plugins:\n          - name: jwt\n            config:\n              claims_to_verify:\n                - exp\n          - name: rate-limiting\n            config:\n              minute: 60\n              policy: local\n\n  # ---------------------------------------------------------\n  # F3 — Collection Workflow Orchestrator\n  # Manages the full job lifecycle state machine\n  # ---------------------------------------------------------\n  - name: workflow-orchestrator\n    url: http://workflow-orchestrator.waste-dev.svc.cluster.local:3002\n    connect_timeout: 3000\n    read_timeout: 30000\n    write_timeout: 30000\n    routes:\n      - name: collection-jobs-api\n        paths:\n          - /api/v1/collection-jobs\n        strip_path: false\n        methods:\n          - GET\n          - POST\n          - PUT\n          - PATCH\n        plugins:\n          - name: jwt\n            config:\n              claims_to_verify:\n                - exp\n          - name: rate-limiting\n            config:\n              minute: 60\n              policy: local\n\n  # ---------------------------------------------------------\n  # F3 — Scheduler Service\n  # Handles driver/vehicle assignment and job progress tracking\n  # ---------------------------------------------------------\n  - name: scheduler-service\n    url: http://scheduler-service.waste-dev.svc.cluster.local:3003\n    connect_timeout: 3000\n    read_timeout: 15000\n    write_timeout: 15000\n    routes:\n      - name: collections-api\n        paths:\n          - /api/v1/collections\n        strip_path: false\n        methods:\n          - GET\n          - POST\n        plugins:\n          - name: jwt\n            config:\n              claims_to_verify:\n                - exp\n          - name: rate-limiting\n            config:\n              minute: 60\n              policy: local\n\n      - name: vehicles-api\n        paths:\n          - /api/v1/vehicles\n        strip_path: false\n        methods:\n          - GET\n        plugins:\n          - name: jwt\n            config:\n              claims_to_verify:\n                - exp\n          - name: rate-limiting\n            config:\n              minute: 60\n              policy: local\n\n  # ---------------------------------------------------------\n  # F2 — FastAPI ML Service\n  # Fill-time predictions, zone generation, route scoring\n  # ---------------------------------------------------------\n  - name: fastapi-ml-service\n    url: http://fastapi-ml-service.waste-dev.svc.cluster.local:8000\n    connect_timeout: 3000\n    read_timeout: 30000\n    write_timeout: 10000\n    routes:\n      - name: ml-api\n        paths:\n          - /api/v1/ml\n        strip_path: false\n        methods:\n          - GET\n          - POST\n        plugins:\n          - name: jwt\n            config:\n              claims_to_verify:\n                - exp\n          - name: rate-limiting\n            config:\n              minute: 30\n              policy: local\n\n  # ---------------------------------------------------------\n  # F3 — Notification Service (WebSocket)\n  # Serves Socket.IO for live dashboard updates\n  # ---------------------------------------------------------\n  - name: notification-service\n    url: http://notification-service.waste-dev.svc.cluster.local:3004\n    connect_timeout: 3000\n    read_timeout: 60000\n    write_timeout: 60000\n    routes:\n      - name: websocket-api\n        paths:\n          - /ws\n        strip_path: false\n        # WebSocket upgrade — no JWT enforcement at gateway level\n        # Auth is handled inside the Socket.IO handshake\n        plugins:\n          - name: rate-limiting\n            config:\n              minute: 10\n              policy: local\n\n# =========================================================\n# GLOBAL PLUGINS\n# Applied to every request passing through Kong\n# =========================================================\nplugins:\n  # Structured request logging — visible in Kong logs\n  - name: file-log\n    config:\n      path: /dev/stdout\n      reopen: false\n\n  # Correlation IDs for distributed tracing (Jaeger-compatible)\n  - name: correlation-id\n    config:\n      header_name: X-Request-ID\n      generator: uuid\n      echo_downstream: true\n"
            },
            "id": "gateway/kong-declarative-config",
            "immutable": false,
            "metadata": [
