                "notes": "\nThank you for installing HashiCorp Vault!\n\nNow that you have deployed Vault, you should look over the docs on using\nVault with Kubernetes available here:\n\nhttps://developer.hashicorp.com/vault/docs\n\n\nYour release is named vault. To learn more about the release, try:\n\n  $ helm status vault\n  $ helm get manifest vault\n\n",
                "revision": 1,
                "values": "{\"global\":{\"enabled\":true},\"injector\":{\"enabled\":true,\"resources\":{\"limits\":{\"cpu\":\"250m\",\"memory\":\"128Mi\"},\"requests\":{\"cpu\":\"50m\",\"memory\":\"64Mi\"}}},\"server\":{\"auditStorage\":{\"enabled\":false},\"dataStorage\":{\"enabled\":false},\"dev\":{\"devRootToken\":\"swms-vault-dev-root-token\",\"enabled\":true},\"livenessProbe\":{\"enabled\":true,\"initialDelaySeconds\":60,\"path\":\"/v1/sys/health?standbyok=true\"},\"readinessProbe\":{\"enabled\":true,\"path\":\"/v1/sys/health?standbyok=true\\u0026sealedcode=204\\u0026uninitcode=204\"},\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"256Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"128Mi\"}},\"service\":{\"enabled\":true,\"port\":8200,\"type\":\"ClusterIP\"}},\"ui\":{\"enabled\":true,\"serviceType\":\"ClusterIP\"}}",
