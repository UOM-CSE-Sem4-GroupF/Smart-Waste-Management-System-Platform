---
extends: default

rules:
  line-length:
    max: 150
    level: warning

  comments:
    min-spaces-from-content: 1

  truthy:
    allowed-values: ['true', 'false', 'yes', 'no', 'on', 'off']
    check-keys: false

  document-start: disable

  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false
