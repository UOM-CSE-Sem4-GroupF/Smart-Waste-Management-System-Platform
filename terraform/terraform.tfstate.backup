            "upgrade_install": null,
            "values": [
              "# Group F — Smart Waste Management System\r\n# HashiCorp Vault — Helm Values (Local Dev)\r\n# Chart: hashicorp/vault (official Helm chart)\r\n# Deployed into: auth namespace\r\n# Mode: Development (in-memory, auto-unsealed, single node)\r\n#\r\n# Usage: helm upgrade --install vault hashicorp/vault -n auth -f auth/vault/values-dev.yaml\r\n\r\nglobal:\r\n  enabled: true\r\n\r\n# ─── Server Configuration ────────────────────────────────────────\r\nserver:\r\n  # Dev mode: single node, in-memory storage, auto-unsealed\r\n  # Root token is printed in pod logs on first startup\r\n  dev:\r\n    enabled: true\r\n    devRootToken: \"swms-vault-dev-root-token\"\r\n\r\n  # Expose UI and API on a NodePort for Minikube access\r\n  service:\r\n    enabled: true\r\n    type: ClusterIP\r\n    port: 8200\r\n\r\n  # Resource limits appropriate for Minikube\r\n  resources:\r\n    requests:\r\n      memory: 128Mi\r\n      cpu: 100m\r\n    limits:\r\n      memory: 256Mi\r\n      cpu: 500m\r\n\r\n  # Readiness probe — Vault is ready when it returns unsealed status\r\n  readinessProbe:\r\n    enabled: true\r\n    path: \"/v1/sys/health?standbyok=true\u0026sealedcode=204\u0026uninitcode=204\"\r\n\r\n  # Liveness probe\r\n  livenessProbe:\r\n    enabled: true\r\n    path: \"/v1/sys/health?standbyok=true\"\r\n    initialDelaySeconds: 60\r\n\r\n  # Data storage — in-memory for dev mode (no PVC needed)\r\n  dataStorage:\r\n    enabled: false\r\n\r\n  # Audit storage disabled for dev mode\r\n  auditStorage:\r\n    enabled: false\r\n\r\n# ─── UI ──────────────────────────────────────────────────────────\r\nui:\r\n  enabled: true\r\n  serviceType: ClusterIP\r\n\r\n# ─── Injector (Vault Agent Injector) ─────────────────────────────\r\n# Enabled: this deploys the mutating webhook that auto-injects\r\n# secrets as sidecar containers into annotated pods.\r\n# Phase 3: Vault is running but injector wiring to existing services\r\n#          is deferred — other teams' services are not affected.\r\ninjector:\r\n  enabled: true\r\n  resources:\r\n    requests:\r\n      memory: 64Mi\r\n      cpu: 50m\r\n    limits:\r\n      memory: 128Mi\r\n      cpu: 250m\r\n"
            ],
            "verify": false,
            "version": "0.32.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "aws_eks_cluster.main",
            "aws_eks_node_group.main",
            "aws_iam_role.eks_cluster",
            "aws_iam_role.eks_nodes",
            "aws_iam_role_policy_attachment.ebs_csi",
            "aws_iam_role_policy_attachment.ecr_read_only",
            "aws_iam_role_policy_attachment.eks_cluster_policy",
            "aws_iam_role_policy_attachment.eks_cni_policy",
            "aws_iam_role_policy_attachment.eks_worker_node",
            "aws_route_table.private",
            "aws_subnet.private",
            "aws_subnet.public",
            "aws_vpc.main",
            "aws_vpc_endpoint.s3",
            "data.aws_eks_cluster.main",
            "data.aws_eks_cluster_auth.main",
            "kubernetes_namespace.swms"
          ]
        }
      ]
    },
